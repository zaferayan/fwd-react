    {
      "id": "q1vnzdrLm3iSMmLXu9GR2",
      "type": "text",
      "x": -459.2693127389707,
      "y": 20643.091283887974,
      "width": 679.5597534179688,
      "height": 595,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
