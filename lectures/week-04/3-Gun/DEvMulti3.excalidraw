      "seed": 1886928434,
      "version": 400,
      "versionNonce": 1232519410,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1775407850127,
      "link": null,
      "locked": false,
      "text": "Yeni bir array oluştururlar hafızada\nmap => elemanları map eder\nfilter => eleman silmeye yarar\neklemek için\n[...array, \"yeni eleman\"]\n\nBaşa eklemek için\n[\"yeni eleman\", ...array]\n\nSilmek için filter\nEklemek için [...arr, newItem]\nListelemek için map\n\n\nEkleme/Çıkarma/Listeleme + TypeScript + DaisyUI\n\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Yeni bir array oluştururlar hafızada\nmap => elemanları map eder\nfilter => eleman silmeye yarar\neklemek için\n[...array, \"yeni eleman\"]\n\nBaşa eklemek için\n[\"yeni eleman\", ...array]\n\nSilmek için filter\nEklemek için [...arr, newItem]\nListelemek için map\n\n\nEkleme/Çıkarma/Listeleme + TypeScript + DaisyUI\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
